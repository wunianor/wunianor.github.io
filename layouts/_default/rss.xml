{{- $pages := where site.RegularPages "Section" "in" (slice "notes" "blog" "projects") -}}
{{- $pages = $pages.ByDate.Reverse | first 20 -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site.Title }}</title>
    <link>{{ site.BaseURL }}</link>
    <description>{{ with site.Params.description }}{{ . }}{{ else }}{{ site.Title }}{{ end }}</description>
    <generator>Hugo {{ hugo.Version }}</generator>
    <language>{{ site.Language.LanguageCode }}</language>
    {{- with $pages -}}
    <lastBuildDate>{{ (index . 0).Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>
    {{- end -}}
    {{ with .OutputFormats.Get "RSS" -}}
    <atom:link href="{{ .Permalink | safeURL }}" rel="self" type="application/rss+xml"/>
    {{- end -}}
    {{- range $pages -}}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <description><![CDATA[{{ .Summary }}]]></description>
    </item>
    {{- end -}}
  </channel>
</rss>
